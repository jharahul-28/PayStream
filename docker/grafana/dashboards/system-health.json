{
  "id": null,
  "title": "PayStream — System Health",
  "tags": ["paystream", "health", "infrastructure"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Circuit Breaker States",
      "type": "stat",
      "gridPos": {"h": 4, "w": 12, "x": 0, "y": 0},
      "targets": [{
        "expr": "resilience4j_circuitbreaker_state",
        "legendFormat": "{{name}}"
      }]
    },
    {
      "id": 2,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{
        "expr": "paystream_kafka_consumer_lag",
        "legendFormat": "{{topic}} - {{consumerGroup}}"
      }]
    },
    {
      "id": 3,
      "title": "JVM Heap Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{
        "expr": "jvm_memory_used_bytes{area=\"heap\"}",
        "legendFormat": "{{job}} heap"
      }]
    },
    {
      "id": 4,
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{
        "expr": "rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])",
        "legendFormat": "{{job}} 5xx"
      }]
    },
    {
      "id": 5,
      "title": "DLQ Messages Total",
      "type": "stat",
      "gridPos": {"h": 4, "w": 12, "x": 0, "y": 12},
      "targets": [{
        "expr": "paystream_kafka_dlq_messages_total",
        "legendFormat": "{{topic}}"
      }]
    }
  ]
}
